# .forceignore - excludes files from force:source:push, force:source:pull, force:source:status
# https://developer.salesforce.com/docs/atlas.en-us.sfdx_dev.meta/sfdx_dev/sfdx_dev_exclude_source.htm

package.xml

# LWC configuration
**/jsconfig.json
**/.eslintrc.json

# LWC Jest tests (exclude from deploy; run locally)
**/__tests__/**

# Bot metadata: Agent Script agents are managed via sf agent publish, not metadata deploy.
# Deploying Bot/BotVersion from source fails validation (entryDialog, conversation variables).
# Use: sf agent publish authoring-bundle --api-name <agent> --target-org <org>
force-app/main/default/bots/**
